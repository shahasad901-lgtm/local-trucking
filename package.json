{
  "name": "local-trucking",
  "version": "1.0.0",
  "description": "Local Trucking - Logistics Billing & Driver Registry Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "frontend": "cd frontend && node node_modules/vite/bin/vite.js",
    "install-all": "npm install && npm install --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run frontend\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
